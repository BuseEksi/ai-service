APP_NAME=AI Service
APP_ENV=development
DEBUG=true

# provider: "anthropic" veya test icin "mock"
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=

API_PREFIX=/api/v1

LLM_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# provider: "openai" seçilirse
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SLACK_BOT_TOKEN=

# Faz 6: Authentication - /chat ve /emails endpoint'leri için X-API-Key
# header'ında beklenen değer(ler). Virgülle ayrılmış birden fazla key
# tanımlanabilir (örn: her tüketici için ayrı key).

API_KEYS=change-me-local-dev-key
